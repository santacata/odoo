<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ====================================================== -->
    <!--                       MENU ARREL                       -->
    <!-- ====================================================== -->

    <menuitem id="menu_natacio_root"
              name="Natacio"
              sequence="1"/>

    <!-- ====================================================== -->
    <!-- ========================= CATEGORIES ================= -->
    <!-- ====================================================== -->

    <record id="action_natacio_categories" model="ir.actions.act_window">
        <field name="name">Categories</field>
        <field name="res_model">natacio.categoria</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_natacio_categories"
              name="Categories"
              parent="menu_natacio_root"
              action="action_natacio_categories"
              sequence="20"/>

    <!-- ====================================================== -->
    <!-- ========================= CLUBS ======================= -->
    <!-- ====================================================== -->

    <record id="action_natacio_clubs" model="ir.actions.act_window">
        <field name="name">Clubs</field>
        <field name="res_model">natacio.club</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_natacio_clubs"
              name="Clubs"
              parent="menu_natacio_root"
              action="action_natacio_clubs"
              sequence="10"/>

    <record id="view_natacio_club_list" model="ir.ui.view">
        <field name="name">natacio.club.list</field>
        <field name="model">natacio.club</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="poble"/>
                <field name="num_socis"/>
            </list>
        </field>
    </record>

    <record id="view_natacio_club_form" model="ir.ui.view">
        <field name="name">natacio.club.form</field>
        <field name="model">natacio.club</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="poble"/>
                        <field name="num_socis"/>
                    </group>
                    <group string="Nadadors">
                        <field name="nadadors_ids"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ====================================================== -->
    <!-- ======================= NADADORS ====================== -->
    <!-- ====================================================== -->

    <record id="action_natacio_nadadors" model="ir.actions.act_window">
        <field name="name">Nadadors</field>
        <field name="res_model">natacio.nadador</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_natacio_nadadors"
              name="Nadadors"
              parent="menu_natacio_root"
              action="action_natacio_nadadors"
              sequence="30"/>

    <record id="view_natacio_nadador_list" model="ir.ui.view">
        <field name="name">natacio.nadador.list</field>
        <field name="model">natacio.nadador</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="any_naixement"/>
                <field name="edat"/>
                <field name="categoria_id"/>
                <field name="club_id"/>
                <field name="progres_pagament" widget="progressbar"/>
                <field name="data_ultim_pagament"/>
            </list>
        </field>
    </record>

    <record id="view_natacio_nadador_form" model="ir.ui.view">
        <field name="name">natacio.nadador.form</field>
        <field name="model">natacio.nadador</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group string="Dades Generals">
                        <field name="name"/>
                        <field name="any_naixement"/>
                        <field name="edat" readonly="1"/>
                        <field name="categoria_id"/>
                        <field name="club_id"/>
                        <field name="progres_pagament" widget="progressbar"/>
                        <field name="data_ultim_pagament"/>
                        <button name="registrar_pagament"
                                type="object"
                                string="Registrar Pagament"/>
                    </group>

                    <group string="Millors Temps">
                        <field name="temps_crol"/>
                        <field name="temps_esquena"/>
                        <field name="temps_brasa"/>
                        <field name="temps_papallona"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ====================================================== -->
    <!-- ========================= ESTILS ====================== -->
    <!-- ====================================================== -->

    <record id="action_natacio_estils" model="ir.actions.act_window">
        <field name="name">Estils</field>
        <field name="res_model">natacio.estil</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_natacio_estils"
              name="Estils"
              parent="menu_natacio_root"
              action="action_natacio_estils"
              sequence="40"/>

    <record id="view_natacio_estil_list" model="ir.ui.view">
        <field name="name">natacio.estil.list</field>
        <field name="model">natacio.estil</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="view_natacio_estil_form" model="ir.ui.view">
        <field name="name">natacio.estil.form</field>
        <field name="model">natacio.estil</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                    <group string="Millors Nadadors">
                        <field name="millors_nadadors_ids"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ====================================================== -->
    <!-- ====================== CAMPIONATS ===================== -->
    <!-- ====================================================== -->

    <record id="action_natacio_campionats" model="ir.actions.act_window">
        <field name="name">Campionats</field>
        <field name="res_model">natacio.campionat</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_natacio_campionats"
              name="Campionats"
              parent="menu_natacio_root"
              action="action_natacio_campionats"
              sequence="50"/>

    <record id="view_natacio_campionat_list" model="ir.ui.view">
        <field name="name">natacio.campionat.list</field>
        <field name="model">natacio.campionat</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="data_inici"/>
                <field name="data_fi"/>
            </list>
        </field>
    </record>

    <record id="view_natacio_campionat_form" model="ir.ui.view">
        <field name="name">natacio.campionat.form</field>
        <field name="model">natacio.campionat</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="club_ids"/>
                        <field name="data_inici"/>
                        <field name="data_fi"/>
                    </group>

                    <group string="Nadadors Inscrits">
                        <field name="nadadors_inscrits_ids"/>
                    </group>

                    <group string="Sessions">
                        <field name="sessio_ids"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ====================================================== -->
    <!-- ========================= SESSIONS ==================== -->
    <!-- ====================================================== -->

    <record id="action_natacio_sessions" model="ir.actions.act_window">
        <field name="name">Sessions</field>
        <field name="res_model">natacio.sessio</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_natacio_sessions"
              name="Sessions"
              parent="menu_natacio_root"
              action="action_natacio_sessions"
              sequence="60"/>

    <record id="view_natacio_sessio_list" model="ir.ui.view">
        <field name="name">natacio.sessio.list</field>
        <field name="model">natacio.sessio</field>
        <field name="arch" type="xml">
            <list>
                <field name="data"/>
                <field name="campionat_id"/>
            </list>
        </field>
    </record>

    <record id="view_natacio_sessio_form" model="ir.ui.view">
        <field name="name">natacio.sessio.form</field>
        <field name="model">natacio.sessio</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="data"/>
                        <field name="campionat_id"/>
                    </group>

                    <group string="Proves">
                        <field name="prova_ids"/>
                    </group>

                    <group string="Nadadors Inscrits">
                        <field name="nadadors_ids"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ====================================================== -->
    <!-- ========================== PROVES ===================== -->
    <!-- ====================================================== -->

    <record id="action_natacio_proves" model="ir.actions.act_window">
        <field name="name">Proves</field>
        <field name="res_model">natacio.prova</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_natacio_proves"
              name="Proves"
              parent="menu_natacio_root"
              action="action_natacio_proves"
              sequence="70"/>

    <record id="view_natacio_prova_list" model="ir.ui.view">
        <field name="name">natacio.prova.list</field>
        <field name="model">natacio.prova</field>
        <field name="arch" type="xml">
            <list>
                <field name="descripcio"/>
                <field name="estil_id"/>
                <field name="categoria_id"/>
                <field name="sessio_id"/>
            </list>
        </field>
    </record>

    <record id="view_natacio_prova_form" model="ir.ui.view">
        <field name="name">natacio.prova.form</field>
        <field name="model">natacio.prova</field>
        <field name="arch" type="xml">
            <form>
                <sheet>

                    <group>
                        <field name="descripcio"/>
                        <field name="estil_id"/>
                        <field name="categoria_id"/>
                        <field name="sessio_id"/>
                    </group>

                    <group string="Inscrits">
                        <field name="nadadors_ids"/>
                    </group>

                    <group string="Sèries">
                        <field name="series_data" widget="text"/>
                    </group>

                    <group string="Resultats">
                        <field name="resultats_data" widget="text"/>
                    </group>

                </sheet>
            </form>
        </field>
    </record>

</odoo>